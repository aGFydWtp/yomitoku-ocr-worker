{
  "name": "yomitoku-ocr-worker",
  "version": "0.1.0",
  "bin": {
    "yomitoku-ocr-worker": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:api": "pnpm --filter yomitoku-api test",
    "cdk": "cdk",
    "lint": "biome check . && bash scripts/check-legacy-refs.sh",
    "lint:fix": "biome check --write .",
    "lint:legacy": "bash scripts/check-legacy-refs.sh",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/jest": "^29",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1108.0",
    "cdk-nag": "^2.37.55",
    "esbuild": "^0.27.3",
    "jest": "^29",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.240.0",
    "constructs": "^10.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
